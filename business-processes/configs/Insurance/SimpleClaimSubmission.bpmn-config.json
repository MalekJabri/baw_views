{
  "process": {
    "id": "proc-insurance-001",
    "name": "Simple Claim Submission Process",
    "description": "Basic insurance claim submission and approval workflow",
    "version": "1.0.0"
  },
  "metadata": {
    "context": "Insurance",
    "complexity": "simple",
    "estimatedDuration": "3-5 days",
    "createdBy": "BAW Blueprint Parser",
    "createdDate": "2026-05-15T08:11:00Z",
    "sourceDocument": "business-blueprints/Insurance-Claims-Process.pdf"
  },
  "roles": [
    {
      "id": "role-policyholder",
      "name": "Policyholder",
      "type": "human",
      "description": "Customer submitting the insurance claim"
    },
    {
      "id": "role-system",
      "name": "Claims System",
      "type": "system",
      "description": "Automated claims processing system"
    },
    {
      "id": "role-adjuster",
      "name": "Claims Adjuster",
      "type": "human",
      "description": "Reviews and approves/denies claims"
    }
  ],
  "milestones": [
    {
      "id": "ms-claim-submitted",
      "name": "Claim Submitted",
      "description": "Initial claim submission received"
    },
    {
      "id": "ms-review-complete",
      "name": "Review Complete",
      "description": "Claim review and decision made"
    }
  ],
  "elements": [
    {
      "id": "elem-start-1",
      "type": "startEvent",
      "name": "Claim Initiated",
      "outgoing": ["flow-1"]
    },
    {
      "id": "elem-task-1",
      "type": "userTask",
      "name": "Submit Claim",
      "assignee": "role-policyholder",
      "incoming": ["flow-1"],
      "outgoing": ["flow-2"],
      "documentation": "Policyholder submits claim with details and supporting documents"
    },
    {
      "id": "elem-task-2",
      "type": "serviceTask",
      "name": "Validate Claim Data",
      "assignee": "role-system",
      "incoming": ["flow-2"],
      "outgoing": ["flow-3"],
      "documentation": "System validates claim completeness and policy coverage"
    },
    {
      "id": "elem-gateway-1",
      "type": "exclusiveGateway",
      "name": "Claim Valid?",
      "incoming": ["flow-3"],
      "outgoing": ["flow-4", "flow-5"]
    },
    {
      "id": "elem-task-3",
      "type": "userTask",
      "name": "Provide Additional Info",
      "assignee": "role-policyholder",
      "incoming": ["flow-5"],
      "outgoing": ["flow-6"],
      "documentation": "Policyholder provides missing information or documents"
    },
    {
      "id": "elem-task-4",
      "type": "userTask",
      "name": "Review Claim",
      "assignee": "role-adjuster",
      "incoming": ["flow-4", "flow-6"],
      "outgoing": ["flow-7"],
      "documentation": "Claims adjuster reviews claim details and makes decision"
    },
    {
      "id": "elem-gateway-2",
      "type": "exclusiveGateway",
      "name": "Claim Decision",
      "incoming": ["flow-7"],
      "outgoing": ["flow-8", "flow-9"]
    },
    {
      "id": "elem-task-5",
      "type": "serviceTask",
      "name": "Process Payment",
      "assignee": "role-system",
      "incoming": ["flow-8"],
      "outgoing": ["flow-10"],
      "documentation": "System processes approved claim payment"
    },
    {
      "id": "elem-task-6",
      "type": "serviceTask",
      "name": "Send Denial Notice",
      "assignee": "role-system",
      "incoming": ["flow-9"],
      "outgoing": ["flow-11"],
      "documentation": "System sends denial notification with reason"
    },
    {
      "id": "elem-end-1",
      "type": "endEvent",
      "name": "Claim Approved",
      "incoming": ["flow-10"]
    },
    {
      "id": "elem-end-2",
      "type": "endEvent",
      "name": "Claim Denied",
      "incoming": ["flow-11"]
    }
  ],
  "flows": [
    {
      "id": "flow-1",
      "sourceRef": "elem-start-1",
      "targetRef": "elem-task-1"
    },
    {
      "id": "flow-2",
      "sourceRef": "elem-task-1",
      "targetRef": "elem-task-2"
    },
    {
      "id": "flow-3",
      "sourceRef": "elem-task-2",
      "targetRef": "elem-gateway-1"
    },
    {
      "id": "flow-4",
      "name": "Valid",
      "sourceRef": "elem-gateway-1",
      "targetRef": "elem-task-4",
      "conditionExpression": "${claim.isValid == true && claim.isComplete == true}"
    },
    {
      "id": "flow-5",
      "name": "Invalid/Incomplete",
      "sourceRef": "elem-gateway-1",
      "targetRef": "elem-task-3",
      "conditionExpression": "${claim.isValid == false || claim.isComplete == false}"
    },
    {
      "id": "flow-6",
      "sourceRef": "elem-task-3",
      "targetRef": "elem-task-4"
    },
    {
      "id": "flow-7",
      "sourceRef": "elem-task-4",
      "targetRef": "elem-gateway-2"
    },
    {
      "id": "flow-8",
      "name": "Approved",
      "sourceRef": "elem-gateway-2",
      "targetRef": "elem-task-5",
      "conditionExpression": "${decision == 'APPROVED'}"
    },
    {
      "id": "flow-9",
      "name": "Denied",
      "sourceRef": "elem-gateway-2",
      "targetRef": "elem-task-6",
      "conditionExpression": "${decision == 'DENIED'}"
    },
    {
      "id": "flow-10",
      "sourceRef": "elem-task-5",
      "targetRef": "elem-end-1"
    },
    {
      "id": "flow-11",
      "sourceRef": "elem-task-6",
      "targetRef": "elem-end-2"
    }
  ],
  "lanes": [
    {
      "id": "lane-role-policyholder",
      "name": "Policyholder",
      "flowNodeRefs": ["elem-task-1", "elem-task-3"]
    },
    {
      "id": "lane-role-system",
      "name": "Claims System",
      "flowNodeRefs": ["elem-start-1", "elem-task-2", "elem-gateway-1", "elem-task-5", "elem-task-6", "elem-end-1", "elem-end-2"]
    },
    {
      "id": "lane-role-adjuster",
      "name": "Claims Adjuster",
      "flowNodeRefs": ["elem-task-4", "elem-gateway-2"]
    }
  ],
  "businessObjects": [
    {
      "id": "Claim",
      "name": "Claim",
      "path": "business-objects/generated/Insurance/Claim.json",
      "usage": "Input/Output for all claim-related tasks"
    },
    {
      "id": "Policy",
      "name": "Policy",
      "path": "business-objects/generated/Insurance/Policy.json",
      "usage": "Input for validation task"
    },
    {
      "id": "Document",
      "name": "Document",
      "path": "business-objects/generated/Insurance/Document.json",
      "usage": "Input for claim submission"
    }
  ],
  "businessRules": [
    {
      "id": "rule-1",
      "name": "Claim Validation",
      "description": "Claim must have all required fields and be within policy coverage",
      "appliesTo": "elem-task-2"
    },
    {
      "id": "rule-2",
      "name": "Auto-Approval Threshold",
      "description": "Claims under $1000 with complete documentation may be auto-approved",
      "appliesTo": "elem-task-4"
    }
  ]
}